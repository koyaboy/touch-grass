{
  "manifest_version": 3,
  "name": "Touch Grass",
  "description": "Enforced recovery breaks and daily browser shutdown for deep work sessions.",
  "version": "0.1.0",
  "permissions": ["alarms", "offscreen", "storage", "tabs", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "assets/service-worker.js",
    "type": "module"
  },
  "chrome_url_overrides": {
    "newtab": "newtab/index.html"
  },
  "options_page": "settings/index.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Touch Grass",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["sounds/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
